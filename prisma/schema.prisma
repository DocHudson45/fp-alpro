generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum ProjectStatus {
  DRAFT
  DISCOVERY
  ANALYZED
}

model User {
  id        String   @id // Matches Supabase Auth UUID
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects  Project[]
}

model Project {
  id                 String        @id // slug derived from name
  userId             String?
  user               User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // User input fields
  name               String        // Project display name
  description        String        @db.Text // Was "clientRequest"
  businessType       String?
  targetUser         String?
  appGoal            String?       // Was "websiteGoal"
  desiredComplexity  String?
  techStack          String?
  freelancerRate     Int?
  references         String[]
  referenceSummaries String[]      // AI-generated summaries of reference URLs

  status             ProjectStatus @default(DRAFT)
  canvasLayout       Json?         // stores { nodeId: {x, y} }
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  discoveryQAs       DiscoveryQA[]
  analysis           Analysis?
  designValidations  DesignValidation[]
  generatedImages    GeneratedImage[]
}

model DiscoveryQA {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  question    String   @db.Text
  answer      String?  @db.Text
  order       Int

  createdAt   DateTime @default(now())

  @@index([projectId])
}

model Analysis {
  id                 String   @id @default(cuid())
  projectId          String   @unique
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  designDirection    String   @db.Text // Was "websiteDirection"
  uxReasoning        String   @db.Text
  featureScope       Json
  complexity         String
  complexityReason   String   @db.Text
  effortEstimate     Json
  riskFactors        Json
  visualDirection    Json

  builderPrompt      String?  @db.Text
  builderTargetTool  String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model DesignValidation {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  imageUrl    String
  feedback    Json?

  createdAt   DateTime @default(now())

  @@index([projectId])
}

model GeneratedImage {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  prompt      String   @db.Text
  imageUrl    String
  imageType   String   // "moodboard" | "concept" | "fixed"

  createdAt   DateTime @default(now())

  @@index([projectId])
}
